# SAIFE Gateway Configuration Example
# Do not place real keys in this file. Copy to .env and configure.

# Base Configuration
SAIFE_API_KEY=your_saife_api_key_here

# Guard Engine (gRPC)
SAIFE_GUARD_ENGINE_ENDPOINT=localhost:50051
SAIFE_DIRECTIVE_SECRET=your_hmac_secret_for_focus_directives

# TLS Configuration (For Guard Engine mTLS)
SAIFE_TLS_CERT_PATH=./dev-certs/client.crt
SAIFE_TLS_KEY_PATH=./dev-certs/client.key
SAIFE_TLS_CA_PATH=./dev-certs/ca.crt

# Provider Compliance Constraints (Q6)
SAIFE_DPA_EXECUTED=true
SAIFE_TRANSFER_BASIS=DPF
SAIFE_NO_TRAINING_CLAUSE=true
SAIFE_ENDPOINT_REGION=EU
